# Dev proxy must be running first: npm run proxy (bridges :8080 → 127.0.0.1:52159)
#
# Web (Expo web / browser) — proxy on same machine, always localhost
EXPO_PUBLIC_API_BASE_URL_WEB=http://localhost:8080
#
# Native (Expo Go on Android/iOS) — set to your machine's LAN IP
# EXPO_PUBLIC_API_BASE_URL_NATIVE=http://192.168.1.12:8080
#
# Production override (both platforms):
# EXPO_PUBLIC_API_BASE_URL_WEB=https://api.wunderkind.app
# EXPO_PUBLIC_API_BASE_URL_NATIVE=https://api.wunderkind.app
