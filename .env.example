# Local dev (physical device on LAN — run scripts/dev-proxy.py first)
# Uses mDNS hostname so it works across networks without updating the IP.
# *.lndo.site resolves to 127.0.0.1 in DNS — can't use it from a physical device.
EXPO_PUBLIC_API_BASE_URL=http://MacBook-Pro.local:8080

# Production
# EXPO_PUBLIC_API_BASE_URL=https://api.wunderkind.app
